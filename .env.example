# Copy this file to .env and fill in your values.
# Vite exposes ONLY vars prefixed with VITE_ to the client bundle.
# Everything else stays server-side (Netlify function + ingestion script).

# --- Supabase (client-safe) ---
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Math RAG (server-side only — NEVER prefix with VITE_) ---
# Service role bypasses RLS; used by scripts/ingest_pdfs.py to insert chunks.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Voyage AI key for embedding (voyage-3, 1024 dims). Get one at voyageai.com.
VOYAGE_API_KEY=your-voyage-api-key

# --- Admin AI assistant (server-side only) ---
# Anthropic API key powering Leonardo's translate/draft helpers in /admin.
ANTHROPIC_API_KEY=your-anthropic-api-key
